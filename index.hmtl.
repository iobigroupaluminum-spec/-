
<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>იობი | კარ-ფანჯრების წარმოება</title>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        :root {
            --gold: #c5a059;
            --dark: #1a1a1a;
            --white: #ffffff;
            --grey: #f8f9fa;
        }

        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--white);
            color: #333;
            line-height: 1.6;
            scroll-behavior: smooth;
        }

        /* ნავიგაცია */
        nav {
            background: var(--dark);
            padding: 20px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: fixed;
            width: 90%;
            top: 0;
            z-index: 1000;
            border-bottom: 2px solid var(--gold);
        }

        .logo {
            color: var(--gold);
            font-size: 28px;
            font-weight: bold;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        /* მთავარი სექცია */
        .hero {
            height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), 
                        url('https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=1350&q=80');
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: clamp(3.5rem, 10vw, 6rem);
            color: var(--gold);
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 5px;
        }

        .hero p {
            font-size: 1.5rem;
            margin-top: 10px;
            max-width: 600px;
        }

        /* სერვისების სექცია */
        .services {
            padding: 100px 10%;
            text-align: center;
        }

        .section-title {
            font-size: 2.5rem;
            margin-bottom: 50px;
            position: relative;
            padding-bottom: 15px;
        }

        .section-title::after {
            content: '';
            width: 80px;
            height: 3px;
            background: var(--gold);
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .card {
            background: var(--grey);
            padding: 40px;
            border-radius: 15px;
            transition: 0.4s;
            border: 1px solid #ddd;
        }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            border-color: var(--gold);
        }

        .card h3 {
            color: var(--dark);
            font-size: 1.5rem;
            margin-bottom: 15px;
        }

        /* კონტაქტი */
        .contact-box {
            background: var(--dark);
            color: white;
            padding: 60px;
            border-radius: 20px;
            margin: 50px 10%;
            text-align: center;
        }

        .contact-box h2 {
            color: var(--gold);
            font-size: 2rem;
            margin-bottom: 20px;
        }

        .btn {
            background: var(--gold);
            color: black;
            padding: 18px 40px;
            text-decoration: none;
            font-weight: bold;
            border-radius: 50px;
            display: inline-block;
            margin-top: 20px;
            font-size: 1.1rem;
            transition: 0.3s;
        }

        .btn:hover {
            background: #b08e4a;
            transform: scale(1.05);
        }

        /* WhatsApp ღილაკი */
        .whatsapp-float {
            position: fixed;
            width: 65px;
            height: 65px;
            bottom: 40px;
            right: 40px;
            background-color: #25d366;
            color: #FFF;
            border-radius: 50px;
            text-align: center;
            font-size: 35px;
            box-shadow: 2px 2px 10px rgba(0,0,0,0.3);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }

        footer {
            background: #111;
            color: #888;
            padding: 30px;
            text-align: center;
            font-size: 0.9rem;
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 3rem; }
            .hero p { font-size: 1.2rem; }
        }
    </style>
</head>
<body>

